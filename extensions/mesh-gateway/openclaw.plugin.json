{
  "id": "mesh-gateway",
  "name": "Mesh Gateway",
  "description": "Tokenless Tailscale-authenticated mesh RPC gateway for agent-to-agent task exchange",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean" },
      "displayName": { "type": "string" },
      "agentIdentity": { "type": "string" },
      "allowedUsers": {
        "type": "array",
        "items": { "type": "string" }
      },
      "allowedAgents": {
        "type": "array",
        "items": { "type": "string" }
      },
      "rosterPath": { "type": "string" },
      "omniMem": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "url": { "type": "string" },
          "workspaceId": { "type": "string" }
        }
      }
    }
  }
}
